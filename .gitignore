# OS / editor
.DS_Store
.obsidian/workspace*
.obsidian/cache

# Raw source material (personal ingestion channels — not committed to standalone repo)
raw/_inbox/*
raw/matter/*
raw/notes/*
raw/web/*
raw/youtube/*
raw/sources/*
raw/email/*
raw/pdf/*
raw/book/*
raw/arxiv/*
raw/github/*
raw/x/*

# Keep .gitkeep markers so channel dirs survive clone
!**/.gitkeep

# Python
__pycache__/
.pytest_cache/
*.pyc
*.pyo

# Gmail OAuth secrets (owned-credential transport for collect-email) — never commit
bin/credentials.json
bin/token.json

# Secrets / API keys — never commit
.env
.env.*

# YouTube collector — personal token + playlist policy config
bin/youtube_token.json
bin/youtube_playlists.yaml

# X (Twitter) bookmarks collector — OAuth2 app + token
bin/x_app.json
bin/x_token.json

# Scheduled-run lock + log — single-flight artifacts, always local
# Note: raw/_inbox/_REVIEW.md is already covered by the raw/_inbox/* rule above.
raw/.scheduled_run.lock
raw/.scheduled_run.log

# local-first LLM router usage log
raw/.llm_usage.jsonl

# blog watch-list seen-URL ledger — dedup memory for shelved/pruned backfill
raw/.blog_seen_urls.txt

# whisper youtube-rescue worklists + logs — local feeder state
raw/.whisper_keepers.tsv
raw/.whisper_worklist.tsv
raw/.whisper_rescue.log
raw/.whisper_rescue_run.log
raw/.weekly_synthesis.log

# session scratch — browser-MCP artifacts + superpowers SDD ledger
.playwright-mcp/
.superpowers/
